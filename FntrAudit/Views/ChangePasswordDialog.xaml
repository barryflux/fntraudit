<Window x:Class="FntrAudit.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Changement de mot de passe"
        Width="480"
        Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <materialDesign:Card Padding="20"
                             materialDesign:ShadowAssist.ShadowDepth="Depth2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Changement de mot de passe"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16"/>

                <TextBox Grid.Row="1"
                         x:Name="EmailTextBox"
                         materialDesign:HintAssist.Hint="Entrer le mail utilisateur"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,18"/>

                <UniformGrid Grid.Row="2" Columns="2" HorizontalAlignment="Right">
                    <Button Content="Valider"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="Validate_Click"/>

                    <Button Content="Annuler"
                            Margin="0,0,10,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Click="Cancel_Click"/>
                </UniformGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>