<Window x:Class="FntrAudit.Views.ClientEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:FntrAudit.Viewmodels"
        xmlns:components="clr-namespace:FntrAudit.Views.Components"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="1100"
        Height="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        Background="#F5F5F5">

    <Window.Resources>

        <Style x:Key="CustomExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        SnapsToDevicePixels="True">

                            <DockPanel LastChildFill="True">
                                <!-- HEADER -->
                                <ToggleButton x:Name="HeaderSite"
                                      DockPanel.Dock="Top"
                                      Style="{x:Null}"
                                      MinHeight="52"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Center"
                                      Background="#F3F4F6"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      Padding="0"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">

                                    <Border Padding="16,12"
                                    Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding Header}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               TextWrapping="Wrap"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#1F2937"/>

                                            <TextBlock x:Name="Chevron"
                                               Grid.Column="1"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#555555"
                                               Text="⌄"/>
                                        </Grid>
                                    </Border>
                                </ToggleButton>

                                <!-- CONTENT -->
                                <Border x:Name="ExpandSite"
                                Visibility="Collapsed"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1,1,0,0">
                                    <ContentPresenter Margin="12"
                                              Focusable="False"/>
                                </Border>
                            </DockPanel>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="HeaderSite" Property="Background" Value="#DCEBFF"/>
                                <Setter TargetName="Chevron" Property="Text" Value="⌃"/>
                            </Trigger>

                            <Trigger SourceName="HeaderSite" Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderSite" Property="Background" Value="#EAECEF"/>
                            </Trigger>

                            <Trigger SourceName="HeaderSite" Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderSite" Property="Background" Value="#DDE1E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:Card Grid.Row="0"
                             Padding="20"
                             Margin="0,0,0,16"
                             materialDesign:ShadowAssist.ShadowDepth="Depth2">
            <DockPanel LastChildFill="True">
                <StackPanel>
                    <TextBlock Text="{Binding DialogTitle}"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Informations principales du client et de son contexte"
                               Margin="0,6,0,0"
                               Foreground="#666666"
                               FontSize="14"/>
                </StackPanel>

                <Border DockPanel.Dock="Right"
                        Background="#E8EAF6"
                        CornerRadius="16"
                        Padding="12,6"
                        VerticalAlignment="Top">
                    <TextBlock Text="{Binding ModeLabel}"
                               Foreground="#3949AB"
                               FontWeight="SemiBold"/>
                </Border>
            </DockPanel>
        </materialDesign:Card>

        <!-- Body -->
        <materialDesign:Card Grid.Row="1"
                             Padding="20"
                             materialDesign:ShadowAssist.ShadowDepth="Depth1">
            <TabControl SelectedIndex="0">
                <!-- GENERAL -->
                <TabItem Header="Général">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4">

                            <Expander Header="Informations générales"
                                      Expanded="AccordionExpander_Expanded"
                                      Margin="0,0,0,12"
                                      Style="{StaticResource CustomExpanderStyle}">
                                <Grid Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,10,12"
                                             Text="{Binding Intitule, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Nom de la société / Intitulé"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="10,0,0,12"
                                             Text="{Binding RaisonSociale, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Raison sociale"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,10,12"
                                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Email"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="10,0,0,12"
                                             Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Adresse"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="2" Grid.Column="0" Margin="0,0,10,0"
                                             Text="{Binding Siret, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="SIRET"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="2" Grid.Column="1" Margin="10,0,0,0"
                                             Text="{Binding Naf, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Code NAF"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                            </Expander>

                            <Expander Header="Interlocuteurs"
                                      Expanded="AccordionExpander_Expanded"
                                      Margin="0,0,0,12"
                                      Style="{StaticResource CustomExpanderStyle}">
                                <Grid Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,10,12"
                                             Text="{Binding PersonneSollicitante, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Personne sollicitante"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="10,0,0,12"
                                             Text="{Binding PersonneInterrogee, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Personne interrogée"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,10,0"
                                             Text="{Binding Fonction, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Fonction"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                            </Expander>

                            <Expander Header="Juridique / société"
                                      Expanded="AccordionExpander_Expanded"
                                      Style="{StaticResource CustomExpanderStyle}">
                                <Grid Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,10,12"
                                             Text="{Binding FormeJuridique, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Forme juridique"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="10,0,0,12"
                                             Text="{Binding Statut, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Statut du dirigeant"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,10,12"
                                             Text="{Binding Capital, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Capital"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="10,0,0,12"
                                             Text="{Binding CaAnnuel, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="CA annuel"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="2" Grid.Column="0" Margin="0,0,10,0"
                                             Text="{Binding EtabSecondaire, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Établissement secondaire"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ACTIVITES -->
                <TabItem Header="Activités">
                    <Grid Margin="4">
                        <components:EntityListView
                            ItemsSource="{Binding ActivityItems}"
                            AddCommand="{Binding AddActivityCommand}"
                            EditCommand="{Binding EditActivityCommand}"
                            DeleteCommand="{Binding DeleteActivityCommand}"
                            AddButtonText="Ajouter activité" />     
                    </Grid>
                </TabItem>

                <!-- ORGANISATION -->
                <TabItem Header="Organisation">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4">

                            <Expander Header="Moyens humains"
                                      Expanded="AccordionExpander_Expanded"
                                      Margin="0,0,0,12"
                                      Style="{StaticResource CustomExpanderStyle}">
                                <Grid Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,10,12"
                                             Text="{Binding Effectif, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Effectif"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="10,0,0,12"
                                             Text="{Binding NombreLicence, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Nombre de licences"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,10,0"
                                             Text="{Binding NbreVehiculeMoteur, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Nombre de véhicules moteurs"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                            </Expander>

                            <Expander Header="Tranche d'effectif"
                                      Expanded="AccordionExpander_Expanded"
                                      Margin="0,0,0,12"
                                      Style="{StaticResource CustomExpanderStyle}">
                                <WrapPanel Margin="12">
                                    <RadioButton Content="1 à 10"
                                                 GroupName="EffectifRange"
                                                 Margin="0,0,16,8"
                                                 IsChecked="{Binding Has1SalOrMore}"/>
                                    <RadioButton Content="11 à 50"
                                                 GroupName="EffectifRange"
                                                 Margin="0,0,16,8"
                                                 IsChecked="{Binding Has11SalOrMore}"/>
                                    <RadioButton Content="51 à 300"
                                                 GroupName="EffectifRange"
                                                 Margin="0,0,16,8"
                                                 IsChecked="{Binding Has50SalOrMore}"/>
                                    <RadioButton Content="301 à 1000"
                                                 GroupName="EffectifRange"
                                                 Margin="0,0,16,8"
                                                 IsChecked="{Binding Has300SalOrMore}"/>
                                    <RadioButton Content="+ de 1000"
                                                 GroupName="EffectifRange"
                                                 Margin="0,0,16,8"
                                                 IsChecked="{Binding Has1000SalOrMore}"/>
                                </WrapPanel>
                            </Expander>

                            <Expander Header="Contexte social"
                                      Expanded="AccordionExpander_Expanded"
                                      Style="{StaticResource CustomExpanderStyle}">
                                <WrapPanel Margin="12">
                                    <CheckBox Content="CSE"
                                              Margin="0,0,20,8"
                                              IsChecked="{Binding Cse}"/>
                                    <CheckBox Content="PV de carence"
                                              Margin="0,0,20,8"
                                              IsChecked="{Binding PvCarence}"/>
                                    <CheckBox Content="Voyageur"
                                              Margin="0,0,20,8"
                                              IsChecked="{Binding IsVoyageur}"/>
                                    <CheckBox Content="Marchandise / Transport"
                                              Margin="0,0,20,8"
                                              IsChecked="{Binding IsTransport}"/>
                                </WrapPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- VISUEL -->
                <TabItem Header="Visuel">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4">

                            <Expander Header="Logo de l'entreprise"
                                      Expanded="AccordionExpander_Expanded"
                                      Margin="0,0,0,12"
                                      Style="{StaticResource CustomExpanderStyle}">
                                <Grid Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="220"
                                            Height="140"
                                            CornerRadius="8"
                                            BorderBrush="#D0D0D0"
                                            BorderThickness="1"
                                            Background="#FAFAFA"
                                            Padding="8">
                                        <Image Source="{Binding LogoPreview}"
                                               Stretch="Uniform"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                        <Button Margin="0,0,0,10"
                                                Padding="14,8"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Command="{Binding PickLogoCommand}">
                                            <TextBlock Text="Choisir une image"/>
                                        </Button>

                                        <Button Padding="14,8"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Command="{Binding RemoveLogoCommand}">
                                            <TextBlock Text="Supprimer le logo"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Expander>

                            <Expander Header="Historique"
                                      Expanded="AccordionExpander_Expanded"
                                      Style="{StaticResource CustomExpanderStyle}">
                                <Grid Margin="12">
                                    <TextBox MinHeight="180"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding Historique, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Historique / notes"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </materialDesign:Card>

        <!-- Footer -->
        <materialDesign:Card Grid.Row="2"
                             Padding="16"
                             Margin="0,16,0,0"
                             materialDesign:ShadowAssist.ShadowDepth="Depth1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#C62828"
                           Text="{Binding ErrorMessage}"/>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Margin="0,0,10,0"
                            Padding="16,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CancelCommand}">
                        <TextBlock Text="Annuler"/>
                    </Button>

                    <Button Margin="0,0,10,0"
                            Padding="16,8"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding SaveCommand}">
                        <TextBlock Text="Enregistrer"/>
                    </Button>

                    <Button Padding="16,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding DeleteCommand}"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Supprimer"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</Window>