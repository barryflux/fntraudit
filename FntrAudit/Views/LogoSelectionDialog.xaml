<Window x:Class="FntrAudit.Views.LogoSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Choisir un logo"
        Width="760"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        Background="#F5F5F5">

    <Grid Margin="20">
        <materialDesign:Card Padding="24"
                             materialDesign:ShadowAssist.ShadowDepth="Depth2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Choisir un logo"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding ErrorMessage}"
                           Foreground="#C62828"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Logos}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="160"
                                        Height="150"
                                        Margin="0,0,12,12"
                                        Padding="8"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Command="{Binding DataContext.SelectLogoCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel>
                                        <Border Height="95"
                                                Background="#FAFAFA"
                                                BorderBrush="#DDDDDD"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="6">
                                            <Image Source="{Binding Preview}"
                                                   Stretch="Uniform"/>
                                        </Border>

                                        <TextBlock Text="{Binding Title}"
                                                   Margin="0,8,0,0"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,18,0,0">
                    <Button Content="Annuler"
                            Padding="16,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>